@charset "UTF-8";*,*::before,*::after{box-sizing:border-box}body{font-family:system-ui,-apple-system,BlinkMacSystemFont,segoe ui,Roboto,Oxygen,Ubuntu,Cantarell,open sans,helvetica neue,sans-serif;background-color:#f7f5f1;color:#000;font-weight:400;line-height:1.6;font-size:1.02rem;max-width:50rem;margin:auto;padding:3rem 1.5rem;overflow-y:scroll}h1,h2,h3,h4,h5,h6{font-weight:700;line-height:1.2;font-weight:800}header{margin-bottom:2rem}header a{color:#000}p{margin-bottom:1em}a{color:#f44;text-decoration:none}a:hover{text-decoration:underline}img{max-width:100%;height:auto}figure{margin:0;text-align:center}input,button,textarea,select{font:inherit;color:inherit;background:0 0;border:none;outline:none}.external::after{content:'↗︎'}