@charset "UTF-8";:root{--bg1:#FFF;--bg2:#F2F0E5;--tx1:#100F0F;--tx2:#6F6E69;--lk1:#4385BE;--lk2:#8B7EC8;--ac1:#BC5215;--ac2:#E8705F;--ac3:#F6E2A0;--ac4:#BFE8D9;--border:solid 0.02rem #6F6E69;--font-main:"Zen Old Mincho", serif;--font-mono:Consolas, "Courier New", Courier, Monaco, monospace;--font-weight:500}*,*::before,*::after{box-sizing:border-box;font-weight:var(--font-weight);text-decoration-thickness:.02rem;font-family:var(--font-main);overflow-wrap:break-word;word-break:break-word}ul,ol,dl,hr,p,figure,pre,blockquote,details,table,article,form,video{margin:1rem 0}b,strong{color:var(--ac1)}b,strong,input[type=button] .btn{-webkit-text-stroke:.01em}[disabled]{visibility:hidden}.monospace{font-family:var(--font-mono)}code,pre,kbd,samp{font-size:.95rem;font-family:var(--font-mono);font-weight:400}figcaption,small,footer,sub,sup,ruby rt,.breadcrumb,.footnotes{font-size:.8em!important}body{max-width:62em;margin:0 auto;padding:2rem 1rem;font-size:1.02rem;line-height:1.7;background:var(--bg1);overflow-x:hidden;overflow-y:scroll;color:var(--tx1);-webkit-font-smoothing:antialiased}header,footer{letter-spacing:.07em;line-height:1.2}header{margin-bottom:3rem}header nav{display:flex;align-items:flex-start}header nav h1{margin:0;flex:1 1 5rem}header nav h1 img{max-height:2.5rem;margin:-.2rem 1rem 0 .2rem}header nav a,header nav a:visited{color:var(--tx1)}header nav a{text-decoration:none;font-size:Max(1.1rem,1.5vw)}header nav a:active{color:var(--ac2)}header nav ul{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:.5rem .8rem;flex-wrap:wrap;flex:auto;margin:0;padding:0}@keyframes rotate{from{transform:rotate(0)}to{transform:rotate(360deg)}}footer{margin:1rem 0;text-align:center}section h1:first-child,section h2:first-child,section h3:first-child,article h1:first-child,article h2:first-child,article h3:first-child{margin-top:1rem;margin-bottom:2rem}article{max-width:55rem;margin:0 auto}article figure{width:calc(100% + 2rem);margin-left:-1rem}section{border-bottom:var(--border);padding:1rem 0}section:first-of-type{border-top:var(--border)}h1,h2,h3,h4,h5,h6{line-height:1.2;margin:2em 0 1rem}h1.title,h2.title,h3.title,h4.title,h5.title,h6.title{text-align:center;text-wrap:balance}h1{font-size:1.5rem}h2{font-size:1.35rem}h3{font-size:1.2rem}p{text-align:justify}p img{text-align:start}p:empty{display:none}a{color:var(--lk1);text-decoration:none}a:visited{color:var(--lk2)}a:active{color:var(--ac2)}a sup{color:var(--tx1)}abbr{text-decoration-line:underline;text-decoration-style:wavy;cursor:help}abbr:hover::after,abbr:active::after{content:"：" attr(text);text-decoration:none;font-size:.9rem}mark{background:var(--ac3)}code,kbd{background:var(--ac4)}pre>code{background:0 0}table{border-collapse:collapse;width:100%;table-layout:fixed}table thead{font-size:.9rem}table tr{border-bottom:var(--border)}table th,table td{padding:.5rem;border:none}table th figure,table td figure{max-width:100%;margin:0}ul,ol{padding-left:2rem}ul{list-style:disc}ol{counter-reset:section;list-style-type:none;margin-left:-1em}ol li::before{counter-increment:section;content:counters(section,"–")". "}blockquote{border-left:var(--border);padding-left:2rem}:is(ol,ul) :is(ol,ul){margin:0}ul,ol,th,td{text-align:start;word-break:auto-phrase}pre{max-width:100%;overflow:auto;border:var(--border);padding:1rem}#TableOfContents{border:var(--border);padding:1rem}#TableOfContents ul,#TableOfContents ol{margin:0}#TableOfContents::before{content:"もくじ"}svg{vertical-align:text-top}form{max-width:100%}input,textarea{font-size:1rem;border:none;outline:none;max-width:100%;min-height:1em;padding:.2rem;margin:0 .5rem .5rem 0;border-radius:0;border:var(--border)}input:focus-within,textarea:focus-within{background:var(--bg2)}input[type=button],.btn{font-size:1rem;color:var(--bg1);border:none;background:var(--ac2);padding:.5rem 1rem;margin:0 .5rem .5rem 0;border-radius:.2rem;cursor:pointer;letter-spacing:.05em}input[type=button]:active,.btn:active{color:var(--bg1)}input[type=button]::before,input[type=button]::after,.btn::before,.btn::after{content:""}input[type=button] sup,.btn sup{color:var(--bg1)}button,a button,.button{cursor:pointer;border:none;font-size:1rem;color:var(--lk1);padding:0;background:0 0;margin:0 .5rem .5rem 0;text-decoration:none;line-height:1;white-space:nowrap;letter-spacing:.05em}button::before,button::after,a button::before,a button::after,.button::before,.button::after{color:var(--tx1);font-size:1.2rem}button::before,a button::before,.button::before{content:"{";margin-right:.5rem}button::after,a button::after,.button::after{content:"}";margin-left:.5rem}button:active,a button:active,.button:active{color:var(--ac2)}figure{text-align:center}figure img{max-width:100%;max-height:90vh;width:auto;height:auto;margin:0}figure figcaption{text-align:center;line-height:1.2}img{max-width:100%;height:auto;display:inline-block;opacity:1;transition:opacity .4s;object-fit:contain;object-position:top}img[data-src]{opacity:0}hr{border:none;height:auto;margin:1rem auto;width:100%;border-bottom:var(--border)}hr.dinkus{width:60%;margin:1rem auto;border:none}hr.dinkus::after{content:"＊　＊　＊　＊　＊";display:block;text-align:center;color:var(--tx1);font-size:.9rem;text-align-last:justify}details{margin-left:1rem}details summary{margin-left:-1rem;cursor:pointer}details *:first-of-type{margin-top:0}details *:last-of-type{margin-bottom:0}.footnotes{display:flex;justify-content:flex-end}.footnotes hr{display:none}.footnotes p{margin:0;display:inline}.footnotes ol{margin:0;padding-left:0;width:Min(70vw,25rem)}.footnotes ol li{display:flex}.footnotes ol li::before{counter-increment:section;content:"※" counter(section)"： ";flex:none}video{max-width:100%}.footnote-ref::before{content:"※"}.footnote-ref::after{content:""}blockquote figure,.footnote-ref figure{width:fit-content;margin:0}.external::after{content:'↗︎'}.card{padding:1rem;border:var(--border);outline:var(--border);outline-offset:-.25rem}.single-page-nav,.paginater{display:flex;justify-content:space-between;text-align:center;align-items:center;margin-top:2rem;font-size:1.5rem;gap:1rem}.single-page-nav a,.single-page-nav span,.paginater a,.paginater span{text-decoration:none;color:var(--tx1)}.single-page-nav .num,.paginater .num{font-size:1.2rem;flex:3}.posts-main{display:flex;flex-wrap:wrap;gap:0 3rem;align-items:flex-start}.posts-main .posts-wrap{flex:45rem;max-width:100%}.posts-side-tags,.posts-side-widgets{flex:10rem}.posts-side-tags{display:inline-block}.posts-side-tags span{display:inline-block}.posts-side-widgets{font-size:.8em;display:flex;order:-1;gap:1rem;flex-wrap:wrap;width:100%}.posts-side-widgets #sun-moon #moon,.posts-side-widgets #sun-moon #sun{flex:1 1 16ch;width:16ch;margin-bottom:1rem}.posts-side-widgets #sun-moon #moon img,.posts-side-widgets #sun-moon #sun img{height:1rem;width:1rem;margin-right:.5rem;image-rendering:pixelated}.posts-side-widgets #calendar{flex:0 0 10rem;width:10rem;height:14em}.posts-side-widgets #calendar .calendar-title{display:flex;justify-content:space-between;margin-bottom:.5rem}.posts-side-widgets #calendar .calendar-today{margin-bottom:1rem}.posts-side-widgets #calendar .calendar-date{display:grid;grid-template-columns:repeat(7,1fr);grid-template-rows:repeat(6,1fr);justify-items:center;gap:0;font-size:.7rem}.posts-side-widgets #calendar .calendar-date span.syuku,.posts-side-widgets #calendar .calendar-date span:nth-of-type(7n - 6){color:#d32f2f}.posts-side-widgets #calendar .calendar-date span:nth-of-type(7n){color:#1565c0}.posts-side-widgets #calendar .calendar-date span.today{position:relative}.posts-side-widgets #calendar .calendar-date span.today::after{content:"";display:inline-block;height:1.7em;width:1.7em;background:var(--bg2);z-index:-1;position:absolute;left:50%;top:50%;transform:translate(-50%,-50%)}.page-info{display:flex;margin:1rem 0 0;font-size:.8rem;flex-wrap:wrap}.page-info div:first-child{margin-right:.5rem}.page-info div:last-child{flex:2 1 5em;text-align:end}.images-main .images-item{line-height:1.2em;display:flex;text-decoration:none;border-bottom:var(--border);padding:1rem 0;color:var(--tx1);gap:1rem}.images-main .images-item:first-of-type{border-top:var(--border)}.images-main .images-item:active{color:var(--ac2)}.images-main .images-item .image-wrap{line-height:0;width:Min(10rem,30vw)}.images-main .images-item .image-wrap img{object-fit:cover;aspect-ratio:1/1;object-position:center top}.images-main .images-item .images-info{width:100%;display:flex;justify-content:space-between;flex-wrap:wrap;flex-direction:column;flex:1}.images-main .images-item .title{text-wrap:balance;text-align:start;word-break:break-word;margin-bottom:.2rem}.images-main .images-item .description{font-size:.9rem;overflow:hidden;display:-webkit-box;text-overflow:ellipsis;-webkit-box-orient:vertical;-webkit-line-clamp:3;white-space:break-spaces}.images-main .images-item .category{font-size:.9rem}.images-main .images-item .count{display:flex;flex-direction:column;justify-content:space-between;align-items:flex-end}.images-main .images-item .count .count-image{font-size:.7rem;width:2em;text-align:end;word-break:break-all;line-height:1}.images-main .images-item .count-page,.images-main .images-item .title{font-size:Min(1.4rem,5vw)}.column{column-count:2;column-fill:balance;column-gap:5rem}.float{float:left;width:50%}.float+*{clear:both}#access-counter{block-size:1rem;border:none;inline-size:10rem;margin:auto;overflow:hidden;mix-blend-mode:multiply}::-webkit-scrollbar{width:1rem;height:1rem;background-color:var(--bg1)}::-webkit-scrollbar-track{background-color:var(--bg1);background-image:radial-gradient(var(--tx1) .05rem,var(--bg1) .05rem);background-size:1rem 1rem}::-webkit-scrollbar-thumb{background:0 0;box-shadow:0 0 0 100vh var(--bg1)}@media screen and (max-width:60rem){.posts-main{flex-direction:column}.posts-side-widgets{justify-content:center}}